# Template for NextJS environment variables.

# For local development, copy this file, rename it to .env.local, and fill in the values.
# When deploying live, you'll need to store the vars in Vercel/System config.

# If not set, we provide default values (check `scaffold.config.ts`) so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# To access the values stored in this env file you can use: process.env.VARIABLENAME
# You'll need to prefix the variables names with NEXT_PUBLIC_ if you want to access them on the client side.
# More info: https://nextjs.org/docs/pages/building-your-application/configuring/environment-variables
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# IPFS Configuration
# ==================
# Gateway URLs for fetching IPFS content (client-side)
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
NEXT_PUBLIC_WEB3_STORAGE_GATEWAY=https://w3s.link/ipfs

# IPFS Storage Provider Selection
# Options: auto, local, pinata, web3storage
# - auto (default): Uses local IPFS in dev, auto-detects provider in production
# - local: Force local IPFS node (requires Kubo daemon at http://127.0.0.1:5001)
# - pinata: Force Pinata (requires PINATA_JWT below)
# - web3storage: Force Web3.Storage (requires WEB3_STORAGE_TOKEN below)
IPFS_PROVIDER=auto

# Pinata Configuration
# Get your JWT from https://app.pinata.cloud/developers/api-keys
# Required for production when IPFS_PROVIDER=auto or pinata
# Optional for development (set IPFS_PROVIDER=pinata to use in dev)
PINATA_JWT=

# Web3.Storage Configuration (alternative to Pinata)
# Get your token from https://web3.storage
WEB3_STORAGE_TOKEN=

# Contract Configuration
NEXT_PUBLIC_PAPER_CONTRACT_ADDRESS=

# RPC URL for Base Sepolia (server-side article route / API reads)
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# App URL for x402 payments (use ngrok URL when testing locally)
NEXT_PUBLIC_APP_URL=

# x402 Facilitator URL (optional)
NEXT_PUBLIC_X402_FACILITATOR_URL=https://x402.facilitator.testnet.x402.io

# ENS Subname Registration (paper.eth)
# Parent name used for app usernames.
NEXT_PUBLIC_PAPER_ENS_PARENT=paper.eth
# Client ENS lookup network (should match ENS_CHAIN_ID).
NEXT_PUBLIC_ENS_CHAIN_ID=11155111
# ENS chain/RPC used by server route, typically Sepolia (11155111).
ENS_CHAIN_ID=11155111
ENS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# ENS registry and resolver contracts for the chosen chain.
ENS_REGISTRY_ADDRESS=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_PUBLIC_RESOLVER_ADDRESS=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
# Private key of wallet that controls the parent ENS name and can create subnames.
ENS_SUBNAME_REGISTRAR_PRIVATE_KEY=
